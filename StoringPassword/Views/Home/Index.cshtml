@model IEnumerable<StoringPassword.ViewModels.MessageModel>
@{
    ViewData["Title"] = "Гостьова книга";
}

<div class="text-center">
    <h1 class="display-4">Гостьова книга</h1>
</div>

@if (Context.Session.GetString("Login") != null)
{
    <div class="row mb-4">
        <div class="col-md-8 offset-md-2">
            <form asp-action="AddMessage" asp-controller="Home" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label for="messageText" class="form-label">Ваше повідомлення:</label>
                    <textarea class="form-control" id="messageText" name="text" rows="3" required></textarea>
                </div>
                <div class="form-group mt-2">
                    <button type="submit" class="btn btn-primary">Додати повідомлення</button>
                </div>
            </form>
        </div>
    </div>
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        @if (Model != null && Model.Any())
        {
            @foreach (var message in Model)
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <strong>@message.UserLogin</strong>
                        <span class="text-muted float-end">@message.DateTime.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                    <div class="card-body">
                        <p class="card-text">@message.Text</p>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info">
                Поки що немає жодного повідомлення. Будьте першим!
            </div>
        }
    </div>
</div>